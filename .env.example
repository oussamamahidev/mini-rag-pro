# ============================================================
# mini-rag Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# OpenAI (required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

# MongoDB
# Username and password for the MongoDB admin user
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_this_to_a_strong_password_min_16_chars
MONGO_URL=mongodb://admin:change_this_to_a_strong_password_min_16_chars@mongodb:27017/?authSource=admin
MONGO_DB_NAME=minirag

# Redis (no auth needed in Docker Compose internal network)
REDIS_URL=redis://redis:6379

# Qdrant
QDRANT_URL=http://qdrant:6333

# App Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_32_byte_random_hex_string_here

# Admin (a hardcoded API key for admin endpoints)
# Generate with: python -c "import secrets; print('sk-admin-' + secrets.token_urlsafe(24))"
ADMIN_API_KEY=sk-admin-generate_this_too

# Frontend
NEXT_PUBLIC_API_URL=http://fastapi:8000

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# Backend runtime tuning
STARTUP_TIMEOUT_SECONDS=60
SERVICE_CHECK_TIMEOUT_SECONDS=5
STORAGE_PATH=storage
ALLOWED_ORIGINS=["http://localhost","http://localhost:3000"]

# RAG defaults
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=150
DEFAULT_TOP_K=5
DEFAULT_RETRIEVAL_STRATEGY=hybrid
DEFAULT_RATE_LIMIT_PER_HOUR=100
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HF_HOME=/home/appuser/.cache/huggingface
SENTENCE_TRANSFORMERS_HOME=/home/appuser/.cache/huggingface/sentence-transformers
